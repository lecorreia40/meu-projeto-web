# Database (PostgreSQL)
DATABASE_URL="postgresql://visaops:visaops@localhost:5432/visaops?schema=public"

# Session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"

# File storage root for local development (S3-compatible storage in production)
STORAGE_DIR="./storage"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
