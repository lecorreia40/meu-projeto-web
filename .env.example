# ============================================================================
# Mesa Proprietária com IA — Example environment configuration
# Copy this file to `.env` and fill in values. NEVER commit a real `.env`.
# No secrets belong in this file or in the repository.
# ============================================================================

# --- Safety / execution mode -------------------------------------------------
# Live trading is DISABLED by default. The risk engine blocks any live order
# unless this is explicitly set to "true" AND the Phase 12 readiness checklist
# is complete. Keep this false for the MVP.
LIVE_TRADING_ENABLED=false

# Default execution mode for all orders: "paper" or "live".
# MVP must remain "paper".
EXECUTION_MODE=paper

# --- Application -------------------------------------------------------------
APP_NAME=mesa-proprietaria-ia
APP_ENV=development
LOG_LEVEL=INFO
# Where structured JSONL audit logs are written.
LOG_DIR=./logs

# --- Repositories ------------------------------------------------------------
# "memory" (default for MVP / tests) or "postgres" (Phase 1+ with a real DB).
REPOSITORY_BACKEND=memory

# --- PostgreSQL (only used when REPOSITORY_BACKEND=postgres) ------------------
# Do NOT put real credentials here; this is an example template only.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mesa
POSTGRES_USER=mesa
POSTGRES_PASSWORD=
# Full DSN overrides the individual fields above if provided.
DATABASE_URL=

# --- Redis (Phase 9+, not required for Sprint 1) -----------------------------
REDIS_URL=redis://localhost:6379/0

# --- Broker (Interactive Brokers paper) — NOT connected in Sprint 1 ----------
# These are placeholders for a future paper-trading connection (Phase 9).
# Leaving them blank is correct for the MVP.
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# --- LLM provider (agents run with mock responses in Phase 3) ----------------
# No real key required for the Sprint 1 foundation. Do not hardcode keys.
LLM_PROVIDER=mock
LLM_API_KEY=

# --- Risk policy overrides (optional; defaults live in risk/policy.py) --------
RISK_MAX_RISK_PER_TRADE_PCT=1.0
RISK_MAX_POSITION_SIZE_PCT=2.0
RISK_MAX_DAILY_LOSS_PCT=2.0
RISK_MAX_WEEKLY_LOSS_PCT=5.0
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_TOTAL_EXPOSURE_PCT=20.0
